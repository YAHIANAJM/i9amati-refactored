generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/@prisma/tenant-client"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "tenant"]
}

model Member {
  id               String        @id
  
  syndicResidences Residence[]
  ownedApartments  Apartment[]   @relation("Owner")
  rentedApartments Apartment[]   @relation("Tenant")
  complaints       Complaint[]
  feedPosts        FeedPost[]
  feedComments     FeedComment[]

  @@schema("public")
  @@map("member")
}

enum ApartmentStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
  @@schema("tenant")
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
  @@schema("tenant")
}

enum PaymentType {
  CHARGE
  MAINTENANCE
  REPAIR
  INSURANCE
  OTHER
  @@schema("tenant")
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  @@schema("tenant")
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  @@schema("tenant")
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  @@schema("tenant")
}

model Residence {
  id         String      @id @default(cuid())
  name       String
  address    String
  city       String
  totalUnits Int         @default(0)
  
  syndicMemberId String
  syndicMember   Member      @relation(fields: [syndicMemberId], references: [id])
  
  apartments Apartment[]
  payments   Payment[]
  complaints Complaint[]
  meetings   Meeting[]
  feedPosts  FeedPost[]
  documents  Document[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("residences")
  @@schema("tenant")
}

model Apartment {
  id             String          @id @default(cuid())
  number         String
  floor          Int             @default(0)
  surface        Float
  status         ApartmentStatus @default(VACANT)
  
  ownerMemberId  String
  ownerMember    Member          @relation("Owner", fields: [ownerMemberId], references: [id])
  
  tenantMemberId String?
  tenantMember   Member?         @relation("Tenant", fields: [tenantMemberId], references: [id])
  
  residenceId    String
  residence      Residence       @relation(fields: [residenceId], references: [id], onDelete: Cascade)
  payments       Payment[]
  complaints     Complaint[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([number, residenceId])
  @@map("apartments")
  @@schema("tenant")
}

model Payment {
  id          String        @id @default(cuid())
  amount      Float
  status      PaymentStatus @default(PENDING)
  type        PaymentType   @default(CHARGE)
  dueDate     DateTime
  paidAt      DateTime?
  description String?
  apartmentId String
  apartment   Apartment     @relation(fields: [apartmentId], references: [id])
  residenceId String
  residence   Residence     @relation(fields: [residenceId], references: [id])
  createdAt   DateTime      @default(now())

  @@map("payments")
  @@schema("tenant")
}

model Complaint {
  id             String            @id @default(cuid())
  title          String
  description    String
  status         ComplaintStatus   @default(OPEN)
  priority       ComplaintPriority @default(MEDIUM)
  
  authorMemberId String
  authorMember   Member            @relation(fields: [authorMemberId], references: [id])
  
  apartmentId    String?
  apartment      Apartment?        @relation(fields: [apartmentId], references: [id])
  residenceId    String
  residence      Residence         @relation(fields: [residenceId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("complaints")
  @@schema("tenant")
}

model Meeting {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      MeetingStatus @default(SCHEDULED)
  scheduledAt DateTime
  location    String?
  residenceId String
  residence   Residence     @relation(fields: [residenceId], references: [id])
  createdAt   DateTime      @default(now())

  @@map("meetings")
  @@schema("tenant")
}

model FeedPost {
  id             String        @id @default(cuid())
  content        String
  
  authorMemberId String
  authorMember   Member        @relation(fields: [authorMemberId], references: [id])
  
  residenceId    String
  residence      Residence     @relation(fields: [residenceId], references: [id])
  comments       FeedComment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("feed_posts")
  @@schema("tenant")
}

model FeedComment {
  id             String   @id @default(cuid())
  content        String
  
  authorMemberId String
  authorMember   Member   @relation(fields: [authorMemberId], references: [id])
  
  postId         String
  post           FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@map("feed_comments")
  @@schema("tenant")
}

model Document {
  id          String    @id @default(cuid())
  name        String
  url         String
  type        String
  size        Int
  residenceId String
  residence   Residence @relation(fields: [residenceId], references: [id])
  uploadedAt  DateTime  @default(now())

  @@map("documents")
  @@schema("tenant")
}
