generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum PlatformRole {
  SUDO
  USER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// ── Better Auth core tables ────────────────────────────────────────────────────

model User {
  id               String       @id
  name             String
  email            String       @unique
  emailVerified    Boolean      @default(false)
  image            String?
  firstName        String?
  lastName         String?
  phone            String?
  role             String?      // reserved for BA admin plugin ("admin" value)
  platformRole     PlatformRole @default(USER)
  banned           Boolean?     @default(false)
  banReason        String?
  banExpires       DateTime?
  twoFactorEnabled Boolean?     @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  sessions        Session[]
  accounts        Account[]
  twofactors      TwoFactor[]
  memberships     OrgMembership[]
  sentInvitations Invitation[]

  @@map("users")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
  impersonatedBy       String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean? @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

// ── Our organization layer ─────────────────────────────────────────────────────

model Organization {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  logo        String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  memberships OrgMembership[]
  invitations Invitation[]
  residences  Residence[]

  @@map("organizations")
}

// answers "can this user access this org's workspace" — no role here
model OrgMembership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("org_memberships")
}

model Invitation {
  id             String           @id @default(cuid())
  email          String
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedById    String
  invitedBy      User             @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())

  @@index([email])
  @@index([organizationId])
  @@map("invitations")
}

// ── Domain enums ───────────────────────────────────────────────────────────────

enum ResidenceStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum UnionType {
  IMMEUBLE
  RESIDENCE
}

enum ApartmentStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

enum UsageType {
  RESIDENTIAL
  COMMERCIAL
  MIXED
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum PaymentType {
  CHARGE
  MAINTENANCE
  REPAIR
  INSURANCE
  OTHER
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Domain models ──────────────────────────────────────────────────────────────
// NOTE: FK fields that pointed to the old BA Member table are now plain String
// fields until the domain profile redesign is complete.

model Residence {
  id             String          @id @default(cuid())
  name           String
  address        String
  city           String?
  status         ResidenceStatus @default(ACTIVE)
  image          String?
  description    String?
  facilities     String[]
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  syndicMemberId String          // → becomes syndicProfileId after domain redesign
  buildings      Building[]
  apartments     Apartment[]
  payments       Payment[]
  complaints     Complaint[]
  meetings       Meeting[]
  feedPosts      FeedPost[]
  documents      Document[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("residences")
}

model Building {
  id                  String      @id @default(cuid())
  name                String
  address             String?
  unionType           UnionType   @default(IMMEUBLE)
  image               String?
  propertyPlanNumber  String?
  numberOfFloors      Int?
  totalUnits          Int         @default(0)
  hasElevator         Boolean     @default(false)
  hasGarage           Boolean     @default(false)
  hasSharedParts      Boolean     @default(false)
  sharedWithTitleDeed String?
  description         String?
  residenceId         String
  residence           Residence   @relation(fields: [residenceId], references: [id])
  apartments          Apartment[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@map("buildings")
}

model Apartment {
  id                    String          @id @default(cuid())
  unitCode              String
  mainPlotNumber        String
  registrationNumber    String?
  floor                 Int?
  areaSqm               Float?
  status                ApartmentStatus @default(VACANT)
  usageType             UsageType       @default(RESIDENTIAL)
  percentageOfApartment Float?
  percentageOfResidence Float?
  buildingId            String
  building              Building        @relation(fields: [buildingId], references: [id])
  residenceId           String
  residence             Residence       @relation(fields: [residenceId], references: [id])
  ownerMemberId         String?         // → becomes ownerProfileId after domain redesign
  tenantMemberId        String?         // → becomes tenantProfileId after domain redesign
  payments              Payment[]
  complaints            Complaint[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@map("apartments")
}

model Payment {
  id          String        @id @default(cuid())
  amount      Float
  status      PaymentStatus @default(PENDING)
  type        PaymentType   @default(CHARGE)
  dueDate     DateTime
  paidAt      DateTime?
  description String?
  apartmentId String
  apartment   Apartment     @relation(fields: [apartmentId], references: [id])
  residenceId String
  residence   Residence     @relation(fields: [residenceId], references: [id])
  createdAt   DateTime      @default(now())

  @@map("payments")
}

model Complaint {
  id             String            @id @default(cuid())
  title          String
  description    String
  status         ComplaintStatus   @default(OPEN)
  priority       ComplaintPriority @default(MEDIUM)
  authorMemberId String            // → becomes authorProfileId after domain redesign
  apartmentId    String?
  apartment      Apartment?        @relation(fields: [apartmentId], references: [id])
  residenceId    String
  residence      Residence         @relation(fields: [residenceId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("complaints")
}

model Meeting {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      MeetingStatus @default(SCHEDULED)
  scheduledAt DateTime
  location    String?
  agenda      String[]
  residenceId String
  residence   Residence     @relation(fields: [residenceId], references: [id])
  createdAt   DateTime      @default(now())

  @@map("meetings")
}

model FeedPost {
  id             String        @id @default(cuid())
  content        String
  authorMemberId String        // → becomes authorProfileId after domain redesign
  residenceId    String
  residence      Residence     @relation(fields: [residenceId], references: [id])
  comments       FeedComment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("feed_posts")
}

model FeedComment {
  id             String   @id @default(cuid())
  content        String
  authorMemberId String   // → becomes authorProfileId after domain redesign
  postId         String
  post           FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@map("feed_comments")
}

model Document {
  id          String    @id @default(cuid())
  name        String
  url         String
  type        String
  size        Int
  residenceId String
  residence   Residence @relation(fields: [residenceId], references: [id])
  uploadedAt  DateTime  @default(now())

  @@map("documents")
}
