# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL on the same VPS (or remote managed DB)
DATABASE_URL="postgresql://i9amati_user:STRONG_PASSWORD@postgres:5432/i9amati"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="production"

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"

# The public URL of your API (what nginx exposes)
BETTER_AUTH_URL="https://api.yourdomain.com/api/auth"

# Allowed browser origins for the frontend that calls this API
# Add your production frontend URL here, plus localhost for local development if needed.
BETTER_AUTH_TRUSTED_ORIGINS="https://your-frontend-domain.com,http://localhost:5173"

# ── External services ────────────────────────────────────────────────────────
GROQ_API_KEY="your-groq-api-key"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
