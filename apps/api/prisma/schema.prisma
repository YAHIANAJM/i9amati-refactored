generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum PlatformRole {
  SUDO
  USER
}

enum ProfileRole {
  SYNDIC
  OWNER
  TENANT
  STAFF
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum ResidenceStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum ApartmentStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

enum UsageType {
  RESIDENTIAL
  COMMERCIAL
  PARKING
  MIXED
}

enum SharedFacilityType {
  GARAGE
  PARKING
  POOL
  GARDEN
  PLAYGROUND
  EQUIPMENT_ROOM
  OTHER
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum PaymentType {
  CHARGE
  MAINTENANCE
  REPAIR
  INSURANCE
  OTHER
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Better Auth core tables ────────────────────────────────────────────────────

model User {
  id               String       @id
  name             String
  email            String       @unique
  emailVerified    Boolean      @default(false) // BA internal — do not remove
  verifiedAt       DateTime?                    // when verification happened
  image            String?
  firstName        String?
  lastName         String?
  phone            String?
  role             String?      // reserved for BA admin plugin ("admin" value)
  platformRole     PlatformRole @default(USER)
  banned           Boolean?     @default(false)
  banReason        String?
  banExpires       DateTime?
  twoFactorEnabled Boolean?     @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  sessions        Session[]
  accounts        Account[]
  twofactors      TwoFactor[]
  profiles        Profile[]
  sentInvitations Invitation[]

  @@map("users")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // which BA credential/provider was used for this session
  accountId            String?
  account              Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  // which org profile is active — set by our login/switch logic
  profileId            String?
  profile              Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  activeOrganizationId String?  // kept for O(1) middleware access without extra join
  impersonatedBy       String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String        @id
  accountId             String
  providerId            String
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // org-scoped OAuth/credential account — null for platform-level accounts
  organizationId        String?
  organization          Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  sessions Session[]

  @@index([userId])
  @@index([organizationId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean? @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

// ── Our organization layer ─────────────────────────────────────────────────────

model Organization {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  logo        String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  accounts          Account[]
  profiles          Profile[]
  invitations       Invitation[]
  residences        Residence[]
  complexes         ResidenceComplex[]
  residenceProfiles ResidenceProfile[]
  buildings         Building[]
  apartments        Apartment[]
  payments          Payment[]
  complaints        Complaint[]
  meetings          Meeting[]
  feedPosts         FeedPost[]
  feedComments      FeedComment[]
  documents         Document[]

  @@map("organizations")
}

// The user's account/identity within an organization.
// Replaces OrgMembership — "profile belongs to org, session belongs to profile."
// ResidenceProfile links here (not to User) so all domain activity is org-scoped.
model Profile {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])

  sessions          Session[]
  residenceProfiles ResidenceProfile[]

  @@map("profiles")
}

model Invitation {
  id             String           @id @default(cuid())
  email          String
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedById    String
  invitedBy      User             @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())

  @@index([email])
  @@index([organizationId])
  @@map("invitations")
}

// ── Domain: multi-profile layer ────────────────────────────────────────────────

// One row per (profile, residence, role).
// A profile can be SYNDIC + OWNER in the same residence, but not two OWNERs.
// Links to Profile (not User) so tenant isolation is enforced at the org level.
model ResidenceProfile {
  id             String      @id @default(cuid())
  profileId      String
  profile        Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  residenceId    String
  residence      Residence   @relation(fields: [residenceId], references: [id], onDelete: Cascade)
  role           ProfileRole

  // Syndic mandate fields (null for non-syndic roles). isAdjoint = adjoint syndic.
  mandateStart DateTime?
  mandateEnd   DateTime?
  isAdjoint    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, residenceId, role])
  @@index([profileId])
  @@index([residenceId])
  @@index([organizationId])
  @@index([role])

  ownedApartments  Apartment[]   @relation("ApartmentOwner")
  rentedApartments Apartment[]   @relation("ApartmentTenant")
  complaints       Complaint[]
  feedPosts        FeedPost[]
  feedComments     FeedComment[]

  @@map("residence_profiles")
}

// ── Domain: residence structure ────────────────────────────────────────────────

// Ensemble immobilier (Loi 18-00 Art. 29) — see with yahya for org structure.
model ResidenceComplex {
  id                 String           @id @default(cuid())
  name               String
  titreFoncierGlobal String?
  organizationId     String
  organization       Organization     @relation(fields: [organizationId], references: [id])
  residences         Residence[]
  sharedFacilities   SharedFacility[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@map("residence_complexes")
}

model Residence {
  id             String            @id @default(cuid())
  name           String
  address        String
  city           String?
  titreFoncier   String?
  status         ResidenceStatus   @default(ACTIVE)
  image          String?
  description    String?
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  complexId      String?
  complex        ResidenceComplex? @relation(fields: [complexId], references: [id])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  profiles         ResidenceProfile[]
  buildings        Building[]
  apartments       Apartment[]
  payments         Payment[]
  complaints       Complaint[]
  meetings         Meeting[]
  feedPosts        FeedPost[]
  documents        Document[]
  sharedFacilities SharedFacility[]

  @@map("residences")
}

model Building {
  id             String      @id @default(cuid())
  name           String
  address        String?
  image          String?
  floors         Int?
  hasElevator    Boolean     @default(false)
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  residenceId    String
  residence      Residence   @relation(fields: [residenceId], references: [id])
  apartments     Apartment[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([organizationId])
  @@map("buildings")
}

model Apartment {
  id              String            @id @default(cuid())
  unitCode        String
  lotNumber       String?
  floor           Int?
  areaSqm         Float?
  status          ApartmentStatus   @default(VACANT)
  usageType       UsageType         @default(RESIDENTIAL)
  quotePart       Float?
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  buildingId      String
  building        Building          @relation(fields: [buildingId], references: [id])
  residenceId     String
  residence       Residence         @relation(fields: [residenceId], references: [id])
  ownerProfileId  String?
  ownerProfile    ResidenceProfile? @relation("ApartmentOwner", fields: [ownerProfileId], references: [id])
  tenantProfileId String?
  tenantProfile   ResidenceProfile? @relation("ApartmentTenant", fields: [tenantProfileId], references: [id])
  payments        Payment[]
  complaints      Complaint[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId])
  @@map("apartments")
}

model SharedFacility {
  id          String             @id @default(cuid())
  name        String
  type        SharedFacilityType
  description String?
  complexId   String
  complex     ResidenceComplex   @relation(fields: [complexId], references: [id])
  residences  Residence[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("shared_facilities")
}

model Payment {
  id             String        @id @default(cuid())
  amount         Float
  status         PaymentStatus @default(PENDING)
  type           PaymentType   @default(CHARGE)
  dueDate        DateTime
  paidAt         DateTime?
  description    String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  apartmentId    String
  apartment      Apartment     @relation(fields: [apartmentId], references: [id])
  residenceId    String
  residence      Residence     @relation(fields: [residenceId], references: [id])
  createdAt      DateTime      @default(now())

  @@index([organizationId])
  @@map("payments")
}

model Complaint {
  id              String            @id @default(cuid())
  title           String
  description     String
  status          ComplaintStatus   @default(OPEN)
  priority        ComplaintPriority @default(MEDIUM)
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  authorProfileId String
  authorProfile   ResidenceProfile  @relation(fields: [authorProfileId], references: [id])
  apartmentId     String?
  apartment       Apartment?        @relation(fields: [apartmentId], references: [id])
  residenceId     String
  residence       Residence         @relation(fields: [residenceId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId])
  @@map("complaints")
}

model Meeting {
  id             String        @id @default(cuid())
  title          String
  description    String?
  status         MeetingStatus @default(SCHEDULED)
  scheduledAt    DateTime
  location       String?
  agenda         String[]
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  residenceId    String
  residence      Residence     @relation(fields: [residenceId], references: [id])
  createdAt      DateTime      @default(now())

  @@index([organizationId])
  @@map("meetings")
}

model FeedPost {
  id              String           @id @default(cuid())
  content         String
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id])
  authorProfileId String
  authorProfile   ResidenceProfile @relation(fields: [authorProfileId], references: [id])
  residenceId     String
  residence       Residence        @relation(fields: [residenceId], references: [id])
  comments        FeedComment[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([organizationId])
  @@map("feed_posts")
}

model FeedComment {
  id              String           @id @default(cuid())
  content         String
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id])
  authorProfileId String
  authorProfile   ResidenceProfile @relation(fields: [authorProfileId], references: [id])
  postId          String
  post            FeedPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          FeedComment?     @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies         FeedComment[]    @relation("CommentReplies")
  createdAt       DateTime         @default(now())

  @@index([organizationId])
  @@index([postId])
  @@index([parentId])
  @@map("feed_comments")
}

model Document {
  id             String       @id @default(cuid())
  name           String
  url            String
  type           String
  size           Int
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  residenceId    String
  residence      Residence    @relation(fields: [residenceId], references: [id])
  uploadedAt     DateTime     @default(now())

  @@index([organizationId])
  @@map("documents")
}
