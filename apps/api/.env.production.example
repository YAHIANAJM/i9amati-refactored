# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL on the same VPS (or remote managed DB)
POSTGRES_USER="i9amati_user"
POSTGRES_PASSWORD="change-this-password"
POSTGRES_DB="i9amati"

# API connection string used by the application container
DATABASE_URL="postgresql://i9amati_user:change-this-password@postgres:5432/i9amati"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="production"

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"

# The public URL of your API (what nginx exposes)
BETTER_AUTH_URL="https://srv1765015.hstgr.cloud/api/auth"

# Allowed browser origins for the frontend that calls this API
# Add your production frontend URL here, plus localhost for local development if needed.
BETTER_AUTH_TRUSTED_ORIGINS="https://your-frontend-domain.com,http://localhost:5173"

# ── Social OAuth ─────────────────────────────────────────────────────────────
# Leave blank to disable the provider — only the configured ones appear.
# Google: console.cloud.google.com → Credentials → OAuth 2.0 Client
# Callback URL: https://srv1765015.hstgr.cloud/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Facebook: developers.facebook.com → App → Facebook Login
# Callback URL: https://srv1765015.hstgr.cloud/api/auth/callback/facebook
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave blank to disable email — convocations still get marked in the DB.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ── External services ────────────────────────────────────────────────────────
GROQ_API_KEY="your-groq-api-key"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
